# Database URL for PostgreSQL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://moesio:moesio@localhost:5432/plates

# Flask server
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Config cache TTL in seconds
CONFIG_CACHE_TTL=10

# RTSP monitoring
RTSP_DEBUG_DIR=
RTSP_DEBUG_SAVE_INTERVAL=30
RTSP_JPEG_QUALITY=70
RTSP_RECONNECT_DELAY=3.0
RTSP_RECONNECT_BACKOFF=1.5
RTSP_RECONNECT_DELAY_MAX=30.0
RTSP_FRAME_SLEEP=1.0

# Detections pagination
DETECTIONS_MAX_PER_PAGE=200
